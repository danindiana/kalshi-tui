[Unit]
Description=Kalshi BTC Auto-Trader — runs every 10 min 24/7
Requires=kalshi-auto-trader.service

[Timer]
# Every 10 minutes — catches the 10-40 min window before each hourly settlement.
# Script self-gates: skips if no open market is within MAX_HORIZON_MINUTES.
OnCalendar=*:00,10,20,30,40,50:00
AccuracySec=10
Persistent=false
Unit=kalshi-auto-trader.service

[Install]
WantedBy=timers.target
